# --- Auth --------------------------------------------------------------------
# Two independent ways to authenticate. You can use one, the other, both, or
# neither (loopback-only). Whatever you pick, /mcp will accept it.
#
# 1) Static API key — clients send `Authorization: Bearer <key>`.
#    Generate one with:
#      python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# REMINDERS_API_KEY=
#
# 2) OAuth 2.1 shim — required for clients like Claude Desktop / Cowork that
#    only support custom MCP connectors via OAuth discovery (RFC 9728 + RFC
#    8414 + RFC 7591 DCR). The shim auto-approves /authorize and hands out
#    tokens on /token. It's a rubber stamp — only enable on a loopback bind.
# REMINDERS_OAUTH=1

# --- Bind --------------------------------------------------------------------
# Default 127.0.0.1 (localhost only). Set to 0.0.0.0 only if you're also
# setting REMINDERS_API_KEY and you know what you're exposing.
# REMINDERS_HOST=127.0.0.1
# REMINDERS_PORT=8765

# --- HTTPS -------------------------------------------------------------------
# Some MCP clients (including Cowork) require https:// even for localhost.
# Set both or neither. Generate with mkcert:
#   brew install mkcert nss
#   mkcert -install
#   mkcert localhost 127.0.0.1 ::1
# Then point these at the resulting files (absolute paths).
# REMINDERS_SSL_KEYFILE=/Users/you/apple-reminders-mcp/localhost+2-key.pem
# REMINDERS_SSL_CERTFILE=/Users/you/apple-reminders-mcp/localhost+2.pem

# --- Allowed Host headers ----------------------------------------------------
# FastMCP enables DNS-rebinding protection by default and rejects requests
# whose Host header isn't a localhost variant (HTTP 421 "Invalid Host header").
# That blocks any tunnel or reverse proxy (cloudflared, ngrok, nginx) because
# the upstream Host header is the public hostname.
#
# Comma-separated extra hostnames to add to the allowlist (bare hostnames
# auto-expand to also match any port), OR "*" to disable the host check
# entirely. Safe to disable here because the /mcp endpoint is still gated
# by bearer-token / OAuth auth.
#
# Use "*" with cloudflared quick tunnels (random hostname each launch).
# Use specific hosts for named tunnels / production proxies.
# REMINDERS_ALLOWED_HOSTS=*
# REMINDERS_ALLOWED_HOSTS=mcp.example.com,other.example.com
